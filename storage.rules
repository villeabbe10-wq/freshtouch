rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Dossier pour l'application Fresh Touch Event
    match /freshtouch/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Dossier pour votre autre application (ex: colette-boutique)
    // À adapter selon le nom que vous choisirez pour vos dossiers
    match /colette-boutique/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
