rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Lecture publique TOTALE pour éviter tout blocage à l'affichage
    match /{document=**} {
      allow read: if true;
    }

    // Écriture réservée à l'administrateur
    match /{document=**} {
      allow write: if request.auth != null && (
        request.auth.token.email == "seduceconseil@gmail.com" ||
        exists(/databases/$(database)/documents/authorized_emails/$(request.auth.token.email))
      );
    }
  }
}
